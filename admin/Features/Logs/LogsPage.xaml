<Page x:Class="admin.Features.Logs.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:admin.Features.Logs"
    >
    <Grid
        Margin="5"
        >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Border
            Grid.Column="0"
            Margin="4"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Padding="16"
            CornerRadius="10"
            VerticalAlignment="Stretch"
            MinHeight="200"
            MinWidth="200"
            >
            <StackPanel>
                <TextBlock
                    Text="Запись лога"
                    HorizontalAlignment="Center"
                    FontWeight="SemiBold"
                />
                <TextBlock 
                    Margin="10"
                    Text="{Binding CardText, Mode=OneWay}"
                    TextWrapping="WrapWithOverflow"
                    MaxWidth="250"
                />
            </StackPanel>
        </Border>
        <Grid
            Grid.Column="1"
            >
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <hc:Pagination
                Grid.Row="0"
                PageIndex="{Binding CurrentPage}"
                MaxPageCount="10"
                >
                <hc:Interaction.Triggers>
                    <hc:EventTrigger EventName="CurrentPageUpdated">
                        <hc:EventToCommand Command="{Binding PageUpdatedCommand}" PassEventArgsToCommand="True" />
                    </hc:EventTrigger>
                </hc:Interaction.Triggers>
            </hc:Pagination>
            <DataGrid
                Grid.Row="1"
                Margin="10,10,10,10"
                HorizontalAlignment="Stretch"
                HeadersVisibility="All"
                RowHeaderWidth="60"
                AutoGenerateColumns="False"
                hc:DataGridAttach.ShowRowNumber="True"
                ItemsSource="{Binding LogResponses, Mode=OneWay}"
                CanUserDeleteRows="False"
                CanUserAddRows="False"
                SelectedItem="{Binding SelectedLog, Mode=TwoWay}"
                SelectionMode="Single"
                >
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding Level, Mode=OneWay}"
                        CanUserResize="False"
                        Header="Уровень"
                    />
                    <DataGridTextColumn
                        Binding="{Binding Message, Mode=OneWay}"
                        CanUserResize="False"
                        Header="Сообщение"
                    />
                    <DataGridTextColumn
                        Binding="{Binding Timestamp, Mode=OneWay}"
                        CanUserResize="False"
                        Header="Время"
                    />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <Border
            Grid.Column="2"
            Margin="5"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Padding="5"
            CornerRadius="10"
            VerticalAlignment="Stretch"
            MinHeight="200"
            MinWidth="200"
            >
            <StackPanel>
                <TextBlock
                    Text="Поиск по логам"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                />
                <TextBlock
                    Text="Уровень"
                />
                <ComboBox
                    ItemsSource="{Binding LogLevels}"
                    SelectedItem="{Binding Level}"
                />
                <TextBlock
                    Text="Минимальный уровень"
                    TextWrapping="Wrap"
                />
                <ui:ToggleSwitch
                    IsChecked="True"
                    Command="{Binding SwitchMinimalLevelCommand}"
                />
                <TextBlock
                    Text="Сортировка"
                    TextWrapping="Wrap"
                />
                <ComboBox
                    ItemsSource="{Binding OrderByItems}"
                    SelectedItem="{Binding SelectedSort}"
                />
                <TextBlock
                    Text="По убыванию"
                    TextWrapping="Wrap"
                />
                <ui:ToggleSwitch
                    IsChecked="True"
                    Command="{Binding SwitchAscSortingCommand}"
                />
                <TextBlock
                    Text="Поиск"
                    TextWrapping="Wrap"
                />
                <ui:TextBox
                    PlaceholderText="Напишите что-то..."
                    Text="{Binding SearchText}"
                />
                <ui:Button
                    Margin="15 15 15 5"
                    HorizontalAlignment="Stretch"
                    Content="Поиск"
                    Command="{Binding FetchLogsCommand}"
                />
                <ui:Button
                    Margin="15 10 15 5"
                    HorizontalAlignment="Stretch"
                    Content="Очистить все логи"
                    Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                    Command="{Binding ClearLogsCommand}"
                />
            </StackPanel>
        </Border>
    </Grid>
</Page>

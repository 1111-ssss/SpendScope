<Page x:Class="admin.Features.Logs.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:admin.Features.Logs"
    >
    <Grid
        Margin="5"
        >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Border
            Grid.Column="0"
            Margin="4"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Padding="16"
            CornerRadius="10"
            VerticalAlignment="Stretch"
            MinHeight="200"
            MinWidth="200"
            >
            <StackPanel>
                <TextBlock
                    Text="Запись лога"
                    HorizontalAlignment="Center"
                    FontWeight="SemiBold"
                />
                <TextBlock 
                    Margin="10"
                    Text="{Binding CardText, Mode=OneWay}"
                    TextWrapping="WrapWithOverflow"
                />
            </StackPanel>
        </Border>
        <StackPanel
            Grid.Column="1"
            >
            <hc:Pagination
                PageIndex="{Binding CurrentPage}"
                MaxPageCount="{Binding TotalPages}"
                >
                <hc:Interaction.Triggers>
                    <hc:EventTrigger EventName="CurrentPageUpdated">
                        <hc:EventToCommand Command="{Binding PageUpdatedCommand}" PassEventArgsToCommand="True" />
                    </hc:EventTrigger>
                </hc:Interaction.Triggers>
            </hc:Pagination>
            <DataGrid
                Grid.Column="1"
                Margin="10,10,10,10"
                HorizontalAlignment="Stretch"
                HeadersVisibility="All"
                RowHeaderWidth="60"
                AutoGenerateColumns="False"
                hc:DataGridAttach.ShowRowNumber="True"
                ItemsSource="{Binding LogPageItems, Mode=OneWay}"
                CanUserDeleteRows="False"
                CanUserAddRows="False"
                SelectedItem="{Binding SelectedLog, Mode=TwoWay}"
                SelectionMode="Single"
                >
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding Level, Mode=OneWay}"
                        CanUserResize="False"
                        Header="Уровень"
                    />
                    <DataGridTextColumn
                        Binding="{Binding Message, Mode=OneWay}"
                        CanUserResize="False"
                        Header="Сообщение"
                    />
                    <DataGridTextColumn
                        Binding="{Binding Timestamp, Mode=OneWay}"
                        CanUserResize="False"
                        Header="Время"
                    />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            Margin="5"
            >
            <TextBlock
                Text="Уровень"
            />
            <ComboBox
                ItemsSource="{Binding LogLevels}"
            />
            <TextBlock
                Text="Минимальный уровень"
                TextWrapping="Wrap"
            />
            <ui:ToggleSwitch
                Command="{Binding SwitchMinimalLevelCommand}"
            />
            <TextBlock
                Text="Сортировка"
                TextWrapping="Wrap"
            />
            <ComboBox
                ItemsSource="{Binding Sorting}"
            />
            <TextBlock
                Text="По убыванию"
                TextWrapping="Wrap"
            />
            <ui:ToggleSwitch
            />
            <TextBlock
                Text="Поиск"
                TextWrapping="Wrap"
            />
            <ui:TextBox
                PlaceholderText="Напишите что-то..."
            />
        </StackPanel>
    </Grid>
</Page>

<Page x:Class="admin.Features.Logs.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:admin.Features.Logs"
    >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Border
            Grid.Column="0"
            Margin="4"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Padding="16"
            CornerRadius="10"
            VerticalAlignment="Stretch"
            MinHeight="200"
            MinWidth="100"
            >
            <Label
                Content="{Binding SelectedLogEntry.Level}"
            />
        </Border>
        <StackPanel
            Grid.Column="1"
            >
            <Label Content="Test"/>
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            >
            <TextBlock
                Text="Уровень"
            />
            <ComboBox
            />
            <TextBlock
                Text="Минимальный уровень"
                TextWrapping="Wrap"
            />
            <ComboBox
            />
            <TextBlock
                Text="Сортировка"
                TextWrapping="Wrap"
            />
            <ComboBox
            />
            <TextBlock
                Text="По убыванию"
                TextWrapping="Wrap"
            />
            <ui:ToggleSwitch
            />
            <TextBlock
                Text="Поиск"
                TextWrapping="Wrap"
            />
            <ui:TextBox
                PlaceholderText="Напишите что-то..."
            />
        </StackPanel>
    </Grid>
</Page>

<Page x:Class="admin.Features.UploadVersion.UploadVersionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:admin.Features.Versions"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d" 
    >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Border
            Grid.Column="0"
            Margin="4"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Padding="16"
            CornerRadius="10"
            VerticalAlignment="Stretch"
            MinHeight="200"
            DragDrop.Drop="DragDrop_UploadVersion"
            DragDrop.DragOver="DragDrop_DragOver"
            >
            <Label
                Content="Перетащите сюда apk или ipa файл приложения"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
            />
        </Border>
        <StackPanel
            Margin="4"
            Grid.Column="1"
            >
            <TextBlock
                Text="Загрузка версии"
                HorizontalAlignment="Center"
            />
            <Label
                Margin="0 15 0 0"
                Content="Ветка"
            />
            <ComboBox
                ItemsSource="{Binding Branches, Mode=OneTime}"
                SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
            />
            <Label
                Margin="0 15 0 0"
                Content="Билд"
            />
            <TextBox
                Text="{Binding Build, Mode=OneWay}"
                IsReadOnly="True"
            />
            <Label
                Margin="0 15 0 0"
                Content="Изменения"
            />
            <TextBox
                Text="{Binding Changelog, Mode=TwoWay}"
                TextWrapping="WrapWithOverflow"
            />
            <ui:Button
                Margin="0 20 0 0"
                Content="Загрузить версию"
                Command="UploadVersionCommand"
            />
        </StackPanel>
    </Grid>
</Page>
